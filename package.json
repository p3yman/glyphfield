{
  "name": "@p3yman/glyphfield",
  "version": "0.1.0",
  "description": "Seeded, animated canvas patterns for React.",
  "keywords": [
    "react",
    "canvas",
    "pattern",
    "animation",
    "loading",
    "seeded"
  ],
  "author": "Peyman Eskandari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/p3yman/glyphfield"
  },
  "bugs": {
    "url": "https://github.com/p3yman/glyphfield/issues"
  },
  "homepage": "https://glyphfield.peyman.me",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "vite build && node scripts/copy-cjs-types.mjs",
    "playground": "vite --config vite.playground.config.ts",
    "build:playground": "vite build --config vite.playground.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "publint": "publint",
    "pack:check": "node scripts/verify-package.mjs",
    "verify": "npm run format:check && npm run lint && npm run types && npm run test:coverage && npm run build && npm run build:playground && npm run build-storybook && npm run pack:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepack": "npm run build && npm run publint"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@eslint/js": "10.0.1",
    "@microsoft/api-extractor": "7.58.11",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.5.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.10"
  }
}
